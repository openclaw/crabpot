    {
      "id": "apify",
      "name": "Apify",
      "repo": "https://github.com/apify/apify-openclaw-plugin.git",
      "path": "plugins/apify",
      "priority": "medium",
      "seams": ["tool", "async-job", "polling", "external-api", "catalog-discovery"],
      "expect": {
        "registrations": ["registerTool"]
