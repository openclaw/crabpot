    {
      "id": "web-search-plus",
      "name": "Web Search Plus",
      "repo": "https://github.com/robbyczgw-cla/web-search-plus-plugin.git",
      "path": "plugins/web-search-plus",
      "priority": "medium",
      "seams": ["tool", "provider-routing", "external-api", "env-auth", "extraction"],
      "expect": {
        "registrations": ["registerTool"]
